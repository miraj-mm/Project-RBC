# Supabase Configuration
# Replace these with your actual Supabase project credentials (do not commit real values)
SUPABASE_URL=https://your-supabase-project-url.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# App Configuration
APP_NAME=DONOR
APP_VERSION=1.0.0

# API Configuration
